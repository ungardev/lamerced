---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Button } from '@/components/ui/button'
import { Calendar, User, ArrowLeft } from 'lucide-react'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props
---

<BaseLayout title={post.data.title} description={post.data.description} article={true}>
  <article class="section-padding pt-20 md:pt-28">
    <div class="container-custom max-w-4xl">
      <!-- Back Link -->
      <a href="/blog" class="inline-flex items-center gap-2 text-muted-foreground hover:text-accent-red mb-8 transition-colors">
        <ArrowLeft className="w-4 h-4" />
        <span>Volver al Blog</span>
      </a>
      
      <!-- Header -->
      <header class="mb-12">
        <h1 class="font-sans text-3xl md:text-4xl lg:text-5xl font-medium text-foreground mb-6">
          {post.data.title}
        </h1>
        <p class="text-xl text-muted-foreground mb-6">
          {post.data.description}
        </p>
        
        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-6 text-sm text-muted-foreground">
          <div class="flex items-center gap-2">
            <Calendar className="w-4 h-4" />
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('es-VE', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <div class="flex items-center gap-2">
            <User className="w-4 h-4" />
            <span>{post.data.author}</span>
          </div>
        </div>
      </header>
      
      <!-- Content -->
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
      
      <!-- Back Button -->
      <div class="mt-12 pt-8 border-t">
        <a href="/blog">
          <Button variant="outline">
            <ArrowLeft className="w-4 h-4 mr-2" />
            Volver al Blog
          </Button>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>