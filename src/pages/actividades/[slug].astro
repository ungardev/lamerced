---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Button } from '@/components/ui/button'
import { Calendar, MapPin, Clock, ArrowLeft } from 'lucide-react'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const activities = await getCollection('actividades')
  return activities.map((activity) => ({
    params: { slug: activity.slug },
    props: { activity },
  }))
}

const { activity } = Astro.props
const { Content } = await activity.render()

const categoryColors = {
  deportivo: 'bg-green-100 text-green-700 border-green-200',
  evento: 'bg-blue-100 text-blue-700 border-blue-200',
  cultural: 'bg-purple-100 text-purple-700 border-purple-200',
}

const categoryLabels = {
  deportivo: 'Deportivo',
  evento: 'Evento',
  cultural: 'Cultural',
}
---

<BaseLayout title={activity.data.title} description={activity.data.description} article={true}>
  <article class="section-padding pt-20 md:pt-28">
    <div class="container-custom max-w-4xl">
      <!-- Back Link -->
      <a href="/actividades" class="inline-flex items-center gap-2 text-muted-foreground hover:text-accent-red mb-8 transition-colors">
        <ArrowLeft className="w-4 h-4" />
        <span>Volver a Actividades</span>
      </a>
      
      <!-- Header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class={`px-3 py-1 text-sm font-medium rounded-full border ${categoryColors[activity.data.category]}`}>
            {categoryLabels[activity.data.category]}
          </span>
          <span class="text-sm text-gray-400">{activity.data.subcategory}</span>
        </div>
        
        <h1 class="font-sans text-3xl md:text-4xl lg:text-5xl font-medium text-foreground mb-6">
          {activity.data.title}
        </h1>
        <p class="text-xl text-muted-foreground mb-6">
          {activity.data.description}
        </p>
        
        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-6 text-sm text-muted-foreground">
          <div class="flex items-center gap-2">
            <Calendar className="w-4 h-4" />
            <time datetime={activity.data.date.toISOString()}>
              {activity.data.date.toLocaleDateString('es-VE', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          {activity.data.time && (
            <div class="flex items-center gap-2">
              <Clock className="w-4 h-4" />
              <span>{activity.data.time}</span>
            </div>
          )}
          {activity.data.location && (
            <div class="flex items-center gap-2">
              <MapPin className="w-4 h-4" />
              <span>{activity.data.location}</span>
            </div>
          )}
        </div>
      </header>
      
      {activity.data.image && (
        <div class="mb-12 rounded-2xl overflow-hidden">
          <img 
            src={activity.data.image} 
            alt={activity.data.title}
            class="w-full h-auto"
          />
        </div>
      )}
      
      <!-- Content -->
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
      
      <!-- Back Button -->
      <div class="mt-12 pt-8 border-t">
        <a href="/actividades">
          <Button variant="outline">
            <ArrowLeft className="w-4 h-4 mr-2" />
            Volver a Actividades
          </Button>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>