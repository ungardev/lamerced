---
import { Calendar, MapPin, Clock } from 'lucide-react'

interface Props {
  title: string
  description: string
  category: 'deportivo' | 'evento' | 'cultural'
  subcategory: string
  date: Date
  endDate?: Date
  time?: string
  location?: string
  image?: string
  featured?: boolean
}

const { title, description, category, subcategory, date, endDate, time, location, image, featured } = Astro.props

const categoryColors = {
  deportivo: 'bg-green-100 text-green-700 border-green-200',
  evento: 'bg-blue-100 text-blue-700 border-blue-200',
  cultural: 'bg-purple-100 text-purple-700 border-purple-200',
}

const categoryLabels = {
  deportivo: 'Deportivo',
  evento: 'Evento',
  cultural: 'Cultural',
}

const formatDate = (d: Date) => {
  return d.toLocaleDateString('es-VE', { day: 'numeric', month: 'short', year: 'numeric' })
}

const formatDateRange = (start: Date, end?: Date) => {
  if (end && start.getTime() !== end.getTime()) {
    return `${formatDate(start)} - ${formatDate(end)}`
  }
  return formatDate(start)
}
---

<a href={`/actividades#${title.toLowerCase().replace(/\s+/g, '-')}`} class="group block">
  <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-accent-red/20 transition-all duration-300 hover:-translate-y-1">
    {image && (
      <div class="relative h-48 overflow-hidden">
        <img 
          src={image} 
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
        {featured && (
          <span class="absolute top-3 left-3 px-3 py-1 bg-accent-red text-white text-xs font-bold rounded-full">
            Destacado
          </span>
        )}
      </div>
    )}
    
    <div class="p-5">
      <div class="flex items-center gap-2 mb-3">
        <span class={`px-2.5 py-1 text-xs font-medium rounded-full border ${categoryColors[category]}`}>
          {categoryLabels[category]}
        </span>
        <span class="text-xs text-gray-400">{subcategory}</span>
      </div>
      
      <h3 class="font-sans text-lg font-semibold text-gray-900 mb-2 group-hover:text-accent-red transition-colors duration-200">
        {title}
      </h3>
      
      <p class="text-sm text-gray-500 mb-4 line-clamp-2">
        {description}
      </p>
      
      <div class="flex flex-wrap gap-3 text-xs text-gray-400">
        <div class="flex items-center gap-1.5">
          <Calendar className="w-3.5 h-3.5" />
          <span>{formatDateRange(date, endDate)}</span>
        </div>
        {time && (
          <div class="flex items-center gap-1.5">
            <Clock className="w-3.5 h-3.5" />
            <span>{time}</span>
          </div>
        )}
        {location && (
          <div class="flex items-center gap-1.5">
            <MapPin className="w-3.5 h-3.5" />
            <span>{location}</span>
          </div>
        )}
      </div>
    </div>
  </div>
</a>