    { time: '12:00 - 1:00', activity: 'Almuerzo', type: 'almuerzo' },
    { time: '1:00 - 2:30', activity: 'Clases académicas (Bloque 2)', type: 'clase' },
    { time: '2:30 - 4:00', activity: 'Taller de música y coro', type: 'taller' },
  ],
  martes: [
    { time: '7:00 - 7:30', activity: 'Formación y oración matutina', type: 'formacion' },
    { time: '7:30 - 12:00', activity: 'Clases académicas (Bloque 1)', type: 'clase' },
    { time: '12:00 - 1:00', activity: 'Almuerzo', type: 'almuerzo' },
    { time: '1:00 - 2:30', activity: 'Clases académicas (Bloque 2)', type: 'clase' },
    { time: '2:30 - 4:00', activity: 'Prácticas deportivas (Fútbol, Atletismo)', type: 'taller' },
  ],
  miercoles: [
    { time: '7:00 - 7:30', activity: 'Formación y oración matutina', type: 'formacion' },
    { time: '7:30 - 12:00', activity: 'Clases académicas (Bloque 1)', type: 'clase' },
    { time: '12:00 - 1:00', activity: 'Almuerzo', type: 'almuerzo' },
    { time: '1:00 - 2:30', activity: 'Clases académicas (Bloque 2)', type: 'clase' },
    { time: '2:30 - 3:30', activity: 'Taller de música (Instrumentos)', type: 'taller' },
    { time: '3:30 - 4:00', activity: 'Club de lectura y literatura', type: 'taller' },
