---
interface ScheduleItem {
  time: string
  activity: string
  type: 'clase' | 'taller' | 'evento' | 'formacion' | 'almuerzo'
}

interface Props {
  day: string
  dayLabel: string
  items: ScheduleItem[]
  isActive?: boolean
}

const { day, dayLabel, items, isActive = false } = Astro.props

const getTypeStyle = (type: ScheduleItem['type']) => {
  const styles = {
    clase: 'bg-blue-50 text-blue-700 border-blue-100',
    taller: 'bg-purple-50 text-purple-700 border-purple-100',
    evento: 'bg-green-50 text-green-700 border-green-100',
    formacion: 'bg-amber-50 text-amber-700 border-amber-100',
    almuerzo: 'bg-gray-50 text-gray-500 border-gray-100',
  }
  return styles[type]
}

const getTypeLabel = (type: ScheduleItem['type']) => {
  const labels = {
    clase: 'Clase',
    taller: 'Taller',
    evento: 'Evento',
    formacion: 'Formación',
    almuerzo: 'Almuerzo',
  }
  return labels[type]
}
---

<div 
  class:list={['schedule-day transition-all duration-300', isActive ? 'block opacity-100 scale-100' : 'hidden opacity-0 scale-95']}
  data-day={day}
>
  <div class="space-y-2">
    {items.map((item) => (
      <div class="flex items-center gap-4 p-3 bg-white rounded-xl border border-gray-100 hover:border-accent-red/20 hover:shadow-md transition-all duration-200">
        <div class="w-24 md:w-32 flex-shrink-0">
          <span class="text-sm font-mono font-medium text-accent-red">{item.time}</span>
        </div>
        <div class="flex-1">
          <span class="text-sm font-medium text-gray-800">{item.activity}</span>
        </div>
        <div class:list={['px-2.5 py-1 rounded-full text-xs font-medium border', getTypeStyle(item.type)]}>
          {getTypeLabel(item.type)}
        </div>
      </div>
    ))}
  </div>
</div>