---
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'
import { Heart, Handshake, Scale, Users, Award, HeartHandshake } from 'lucide-react'

const values = [
  {
    icon: Heart,
    title: 'Misericordia',
    description: 'Compasión y sensibilidad ante el sufrimiento de los demás, formando estudiantes solidarios.',
    gradient: 'from-red-50 to-red-100',
    iconBg: 'bg-accent-red',
  },
  {
    icon: Handshake,
    title: 'Solidaridad',
    description: 'Apoyo mutuo y compromiso con la comunidad educativa y quienes más lo necesitan.',
    gradient: 'from-amber-50 to-amber-100',
    iconBg: 'bg-gold',
  },
  {
    icon: Scale,
    title: 'Justicia',
    description: 'Promoción de la equidad y el respeto a los derechos de cada persona en nuestra comunidad.',
    gradient: 'from-gray-50 to-gray-100',
    iconBg: 'bg-accent-red',
  },
  {
    icon: Users,
    title: 'Respeto',
    description: 'Reconocimiento de la dignidad inherente de cada persona, independientemente de sus diferencias.',
    gradient: 'from-red-50 to-red-100',
    iconBg: 'bg-gold',
  },
  {
    icon: HeartHandshake,
    title: 'Trato Familiar',
    description: 'Creación de un ambiente cálido y acogedor donde cada estudiante se siente parte de una familia.',
    gradient: 'from-amber-50 to-amber-100',
    iconBg: 'bg-accent-red',
  },
  {
    icon: Award,
    title: 'Compromiso',
    description: 'Dedicación al logro de los objetivos educativos y al desarrollo integral de cada estudiante.',
    gradient: 'from-gray-50 to-gray-100',
    iconBg: 'bg-gold',
  },
]
---

<section id="valores" class="section-padding bg-white">
  <div class="container-custom">
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="text-sm font-medium text-accent-red uppercase tracking-wider">Nuestros Valores</span>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mt-4 mb-6">
        Formación en Valores
      </h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        Los 10 valores que caracterizan al U.E.P. Colegio La Merced: solidaridad, respeto, justicia, confianza, servicio, misericordia, participación, compromiso, trabajo en equipo y trato familiar.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {values.map((value, index) => (
        <Card class:list={[
          "group relative overflow-hidden border-border hover:border-gold/50 transition-all duration-500",
          "hover:shadow-xl hover:-translate-y-2"
        ]}>
          <div class:list={["absolute inset-0 opacity-5", value.gradient]}></div>
          <CardHeader className="relative z-10">
            <div class:list={["w-14 h-14 rounded-2xl flex items-center justify-center mb-4 shadow-lg group-hover:scale-110 transition-transform duration-300", value.iconBg]}>
              <value.icon className="w-7 h-7 text-white" />
            </div>
            <CardTitle className="text-xl md:text-2xl group-hover:text-accent-red transition-colors duration-300">
              {value.title}
            </CardTitle>
          </CardHeader>
          <CardContent className="relative z-10">
            <p class="text-muted-foreground leading-relaxed">
              {value.description}
            </p>
          </CardContent>
          
          <!-- Hover decorative element -->
          <div class="absolute bottom-0 right-0 w-24 h-24 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            <div class:list={["absolute inset-0 bg-gradient-to-tl", value.gradient, "to-transparent"]}></div>
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>