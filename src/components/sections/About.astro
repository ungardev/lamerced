---
const stats = [
  { value: '69+', label: 'Años de Trayectoria' },
  { value: '456', label: 'Estudiantes Activos' },
  { value: '3', label: 'Niveles Académicos' },
  { value: '1955', label: 'Año de Fundación' },
]
---

<section id="nosotros" class="section-padding bg-white w-full max-w-full overflow-hidden">
  <div class="container-custom w-full max-w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center w-full max-w-full">
      <!-- Image Side -->
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden shadow-xl border border-gray-100">
          <img 
            src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgxCo6C64M6bCgXkgpcQHEwWlThJPst03_q7LA5X9OMLrCTX_QitVbj9tavdKXvjmso8omBOsnIEhHlSAecpJ3lwrIJ65jW0CNJ0r9VHowEi1VFeHXqQhcqNhzkmxMA9KyZBxL5mH1Dqpq6Vja8X8c55Ly06AYr2bpGcNsdqsrkluthjfRIZ_PF8qBq_omj/s554/WhatsApp%20Image%202024-11-04%20at%2014.04.33%20%281%29.jpeg"
            alt="Instalaciones del Colegio La Merced"
            class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
        </div>
        
        <!-- Floating stat card -->
        <div class="absolute -bottom-4 -right-4 md:-right-8 bg-accent-red rounded-2xl shadow-lg p-4 md:p-5 border border-white/30">
          <div class="text-center">
            <div class="font-serif text-3xl md:text-4xl font-medium text-white mb-1">69+</div>
            <div class="text-xs text-white/80">Años de trayectoria</div>
          </div>
        </div>
      </div>

      <!-- Content Side -->
      <div>
        <span class="text-sm font-sans font-medium text-accent-red uppercase tracking-wider">Nuestra História</span>
        <h2 class="font-sans text-3xl md:text-4xl lg:text-4xl font-medium text-gray-900 mt-3 mb-6">
          Tradición Mercedaria
        </h2>
        
        <div class="space-y-4 text-gray-600 font-sans text-base leading-relaxed mb-8">
          <p>
            El <strong class="text-accent-red">U.E.P. Colegio "La Merced"</strong> fue fundado el <strong class="text-accent-red">25 de febrero de 1955</strong> en Caraballeda, 
            Estado La Guaira, por las <strong>Hermanas Mercedarias</strong> originarias de España.
          </p>
          <p>
            Actualmente atendemos a <strong class="text-accent-red">456 estudiantes</strong> de ambos sexos, desde Nivel Inicial hasta Educación Media General, 
            bajo la dirección de la <strong class="text-gray-900">Prof. Elsa Chayele</strong>.
          </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-3">
          {stats.map((stat) => (
            <div class="p-4 bg-accent-red rounded-xl border border-white/30 hover:border-white/50 hover:shadow-md transition-all duration-200">
              <div class="font-serif text-2xl md:text-3xl font-medium text-white mb-0.5">{stat.value}</div>
              <div class="text-xs text-white/80">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>