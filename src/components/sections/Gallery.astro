---

<section id="galeria" class="section-padding bg-gradient-to-b from-gray-50 via-white to-gray-50 w-full max-w-full overflow-hidden">
  <div class="container-custom w-full max-w-full">
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="text-sm font-medium text-accent-red uppercase tracking-wider">Galería</span>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mt-4 mb-6">
        Nuestra Historia en Imágenes
      </h2>
      <div class="w-24 h-1 bg-gradient-to-r from-accent-red via-gold to-accent-red mx-auto mb-6 rounded-full"></div>
<p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        Setenta años de trayectoria educativa formando estudiantes con valores cristianos y preparándolos para un futuro exitoso.
      </p>
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
      {galleryItems.map((item, index) => (
        <div class:list={[
          "group relative overflow-hidden rounded-2xl",
          index === 0 ? "md:col-span-2 aspect-[2/1]" : "aspect-square"
        ]}>
          <img 
            src={item.image}
            alt={item.title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="font-serif text-xl md:text-2xl font-bold text-white mb-1">{item.title}</h3>
              <p class="text-white/80 text-sm">{item.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Features -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature, index) => (
        <div class="bg-white rounded-2xl p-6 border border-border shadow-sm hover:shadow-md hover:border-gold/50 transition-all duration-300 group hover:-translate-y-1">
          <div class:list={[
            "w-14 h-14 rounded-2xl flex items-center justify-center mb-4 transition-all duration-300 group-hover:scale-110",
            index % 2 === 0 ? "bg-accent-red" : "bg-gold"
          ]}>
            <feature.icon className="w-7 h-7 text-white" />
          </div>
          <h3 class="font-serif text-lg font-semibold text-foreground mb-2 group-hover:text-accent-red transition-colors duration-300">{feature.title}</h3>
          <p class="text-sm text-muted-foreground">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>