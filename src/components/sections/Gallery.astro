const features = [
  {
    icon: Building,
    title: "Infraestructura",
    description: "Desde 1958 en nuestras actuales instalaciones",
  },
  {
    icon: GraduationCap,
    title: "Egresados",
    description: "Más de 69 promociones de bachilleres",
  },
  {
    icon: UsersIcon,
    title: "Comunidad",
    description: "Directora Prof. Elsa Chayele y equipo comprometido",
  },
  {
    icon: Heart,
    title: "Carisma Mercedario",
    description: "Fundado por las Hermanas Mercedarias de España",
  },
