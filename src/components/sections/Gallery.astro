  },
  {
    image: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjRYEytcW9N-8eHDJt3v15RtI_imsIdFXLkMvE98KEfU4nLk-D76S1NM6lE2km_zbbHbVLuP4XIQcUwQe_PKXBuNYEayYFAHvPPQmaIrfQBh8fqbgJmKIHMoDVtFaicNPqBt7XMET8D0BR6Si9pmukxbEgcj03lpInJbVDRheGhx1FuC3ouruTclmyIPBcY/s720/WhatsApp%20Image%202024-11-14%20at%2018.46.23.jpeg",
    title: "Escudo Institucional",
    description: "Símbolo de identidad mercedaria",
  },
