    title: "Nuestras Instalaciones",
    description: "Espacios diseñados para el aprendizaje integral",
  },
  {
    image: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgxCo6C64M6bCgXkgpcQHEwWlThJPst03_q7LA5X9OMLrCTX_QitVbj9tavdKXvjmso8omBOsnIEhHlSAecpJ3lwrIJ65jW0CNJ0r9VHowEi1VFeHXqQhcqNhzkmxMA9KyZBxL5mH1Dqpq6Vja8X8c55Ly06AYr2bpGcNsdqsrkluthjfRIZ_PF8qBq_omj/s554/WhatsApp%20Image%202024-11-04%20at%2014.04.33%20%281%29.jpeg",
    title: "Historia y Tradición",
    description: "70 años de trayectoria educativa en Caraballeda",
  },
  {
    image: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEg-fY_wg6QY0EBtoAEwWj9qlHwOf07J7dJhXdpdSjiNB_kqNnTxZlcrNKxRcla6ztLaYo6LCoOB8HbM1ML_3xvCV1mMMFo8htD3LEk_hW0ZxSADnOueKd9lJGSHO3S0ywxCga-ljj3G7-lIohA3RV722smdVUDzQZjVRNOrv_7Nhab0fm0__j8j-Vud8PGq/s16000/WhatsApp%20Image%202024-11-04%20at%2013.55.30.jpeg",
    title: "Comunidad Educativa",
    description: "456 estudiantes desde Inicial hasta Media General",
  },
  {
    image: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjRYEytcW9N-8eHDJt3v15RtI_imsIdFXLkMvE98KEfU4nLk-D76S1NM6lE2km_zbbHbVLuP4XIQcUwQe_PKXBuNYEayYFAHvPPQmaIrfQBh8fqbgJmKIHMoDVtFaicNPqBt7XMET8D0BR6Si9pmukxbEgcj03lpInJbVDRheGhx1FuC3ouruTclmyIPBcY/s720/WhatsApp%20Image%202024-11-14%20at%2018.46.23.jpeg",
    title: "Escudo Institucional",
    description: "Símbolo de identidad mercedaria",
  },
]

const features = [
  {
    icon: Building,
    title: "Infraestructura",
    description: "Desde 1958 en nuestras actuales instalaciones",
  },
  {
    icon: GraduationCap,
    title: "Egresados",
    description: "Más de 69 promociones de bachilleres",
  },
  {
    icon: UsersIcon,
    title: "Comunidad",
    description: "Directora Prof. Elsa Chayele y equipo comprometido",
  },
  {
    icon: Heart,
    title: "Carisma Mercedario",
    description: "Fundado por las Hermanas Mercedarias de España",
  },
]
---

<section id="galeria" class="section-padding bg-white w-full max-w-full overflow-hidden">
  <div class="container-custom w-full max-w-full">
    <!-- Header -->
    <div class="text-center mb-10">
      <span class="text-sm font-sans font-medium text-accent-red uppercase tracking-wider">Galería</span>
      <h2 class="font-sans text-3xl md:text-4xl lg:text-4xl font-medium text-gray-900 mt-3 mb-4">
        Nuestra Historia en Imágenes
      </h2>
      <p class="text-base text-gray-600 font-sans max-w-2xl mx-auto leading-relaxed">
        Setenta años de trayectoria educativa formando estudiantes con valores cristianos.
      </p>
    </div>

    <!-- Carousel -->
    <div class="relative mb-12">
      <div class="overflow-hidden" id="gallery-carousel">
        <div class="flex transition-transform duration-500 ease-out" id="gallery-track">
          {galleryItems.map((item, index) => (
            <div class="flex-shrink-0 w-full md:w-1/2 lg:w-1/3 px-2">
              <div class="group relative overflow-hidden rounded-2xl aspect-[4/3]">
                <img 
                  src={item.image}
                  alt={item.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading={index < 3 ? "eager" : "lazy"}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <div class="absolute bottom-0 left-0 right-0 p-5">
                    <h3 class="font-serif text-lg md:text-xl font-medium text-white mb-1">{item.title}</h3>
                    <p class="text-white/80 text-sm">{item.description}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation Arrows -->
      <button 
        id="gallery-prev"
        class="absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/90 shadow-lg flex items-center justify-center text-gray-700 hover:bg-white hover:text-accent-red transition-all duration-300 z-10"
        aria-label="Anterior"
      >
        <ChevronLeft className="w-5 h-5" />
      </button>
      <button 
        id="gallery-next"
        class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/90 shadow-lg flex items-center justify-center text-gray-700 hover:bg-white hover:text-accent-red transition-all duration-300 z-10"
        aria-label="Siguiente"
      >
        <ChevronRight className="w-5 h-5" />
      </button>

      <!-- Dots -->
      <div class="flex justify-center gap-2 mt-6" id="gallery-dots">
        {galleryItems.map((_, index) => (
          <button 
            class:list={[
              "w-2 h-2 rounded-full transition-all duration-300",
              index === 0 ? "bg-accent-red w-6" : "bg-gray-300 hover:bg-gray-400"
            ]}
            aria-label={`Ir a imagen ${index + 1}`}
            data-dot={index}
          />
        ))}
      </div>
    </div>

    <!-- Features - Compact -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {features.map((feature, index) => (
        <div class="bg-white rounded-xl p-4 border border-border shadow-sm hover:shadow-md hover:border-gold/50 transition-all duration-300 group hover:-translate-y-1">
          <div class:list={[
            "w-10 h-10 rounded-xl flex items-center justify-center mb-3 transition-all duration-300 group-hover:scale-110",
            index % 2 === 0 ? "bg-accent-red" : "bg-gold"
          ]}>
            <feature.icon className="w-5 h-5 text-white" />
          </div>
          <h3 class="font-sans text-sm font-medium text-foreground mb-1 group-hover:text-accent-red transition-colors duration-300">{feature.title}</h3>
          <p class="text-xs text-muted-foreground leading-tight">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('gallery-track');
  const prevBtn = document.getElementById('gallery-prev');
  const nextBtn = document.getElementById('gallery-next');
  const dots = document.querySelectorAll('[data-dot]');
  
  let currentIndex = 0;
  const totalSlides = 3;
  const totalDots = 4;

  function updateCarousel() {
    if (!track) return;
    const slideWidth = window.innerWidth >= 1024 ? 100 / 3 : window.innerWidth >= 768 ? 50 : 100;
    track.style.transform = `translateX(-${currentIndex * slideWidth}%)`;
    
    dots.forEach((dot, index) => {
      if (index === currentIndex) {
        dot.classList.add('bg-accent-red', 'w-6');
        dot.classList.remove('bg-gray-300');
      } else {
        dot.classList.remove('bg-accent-red', 'w-6');
        dot.classList.add('bg-gray-300');
      }
    });
  }

  prevBtn?.addEventListener('click', () => {
    currentIndex = currentIndex > 0 ? currentIndex - 1 : totalDots - 1;
    updateCarousel();
  });

  nextBtn?.addEventListener('click', () => {
    currentIndex = currentIndex < totalDots - 1 ? currentIndex + 1 : 0;
    updateCarousel();
  });

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentIndex = index;
      updateCarousel();
    });
  });

  window.addEventListener('resize', updateCarousel);
</script>