---
import { Button } from 'free-astro-components'
import { Input } from '@/components/ui/input'
import { Label } from '@/components/ui/label'
import { Textarea } from '@/components/ui/textarea'
---

<section id="admisiones" class="section-padding bg-white w-full max-w-full overflow-hidden">
  <div class="container-custom w-full max-w-full">
    <div class="max-w-2xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-10">
        <span class="text-sm font-sans font-medium text-accent-red uppercase tracking-wider">Admisiones</span>
        <h2 class="font-sans text-3xl md:text-4xl lg:text-4xl font-medium text-gray-900 mt-3 mb-5">
          Solicitud de Información
        </h2>
        <p class="text-base text-gray-600 font-sans max-w-xl mx-auto leading-relaxed">
          Complete el formulario y nos pondremos en contacto con usted en un plazo de 24-48 horas.
        </p>
      </div>

        <!-- Form Card -->
        <div class="bg-gray-50 rounded-2xl border border-gray-100 shadow-lg p-6 md:p-8">
          <form 
          class="space-y-6" 
          id="admissions-form"
          action="https://formspree.io/f/your-form-id" 
          method="POST"
        >
          <!-- Parent Name -->
          <div class="space-y-2">
            <Label htmlFor="parentName">Nombre del Representante *</Label>
            <Input 
              id="parentName" 
              name="parentName" 
              placeholder="Ingrese su nombre completo" 
              required
            />
          </div>

          <!-- Email -->
          <div class="space-y-2">
            <Label htmlFor="email">Correo Electrónico *</Label>
            <Input 
              id="email" 
              name="email" 
              type="email"
              placeholder="correo@ejemplo.com" 
              required
            />
          </div>

          <!-- Phone -->
          <div class="space-y-2">
            <Label htmlFor="phone">Teléfono *</Label>
            <Input 
              id="phone" 
              name="phone" 
              type="tel"
              placeholder="0412-123-4567" 
              required
            />
          </div>

          <!-- Student Level -->
          <div class="space-y-2">
            <Label htmlFor="level">Nivel Educativo del Estudiante *</Label>
            <select 
              id="level"
              name="level"
              required
              class="flex h-11 w-full rounded-lg border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
            >
              <option value="">Seleccione el nivel</option>
              <option value="inicial">Educación Inicial (3-5 años)</option>
              <option value="primaria">Primaria (1er-6to grado)</option>
              <option value="media">Educación Media (7mo-4to año)</option>
            </select>
          </div>

          <!-- Message -->
          <div class="space-y-2">
            <Label htmlFor="message">Mensaje (Opcional)</Label>
            <Textarea 
              id="message" 
              name="message"
              placeholder="Cuéntenos sobre su hijo/a y sus intereses..." 
              rows={4}
            />
          </div>

          <!-- Submit Button -->
          <Button 
            type="submit" 
            label="Enviar Solicitud"
            variant="primary"
            icon="arrow-right"
            iconPosition="right"
            class="w-full"
          />

          <p class="text-xs text-muted-foreground text-center">
            Al enviar este formulario, acepta nuestra política de privacidad.
            Nos pondremos en contacto en un plazo de 24-48 horas.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>