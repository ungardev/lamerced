---
interface Props {
  variant?: 'transparent' | 'solid'
}

const { variant = 'transparent' } = Astro.props

const navLinksDesktop = [
  { label: 'Nosotros', href: '/#nosotros' },
  { label: 'Valores', href: '/#valores' },
  { label: 'Galería', href: '/#galeria' },
  { label: 'Testimonios', href: '/#testimonios' },
  { label: 'Blog', href: '/blog' },
  { label: 'Admisiones', href: '/#admisiones', highlight: true },
]

const navLinksMobile = [
  { label: 'Home', href: '/' },
  { label: 'Nosotros', href: '/#nosotros' },
  { label: 'Valores', href: '/#valores' },
  { label: 'Galería', href: '/#galeria' },
  { label: 'Testimonios', href: '/#testimonios' },
  { label: 'Blog', href: '/blog' },
  { label: 'Admisiones', href: '/#admisiones', highlight: true },
  { label: 'Contacto', href: '/#footer' },
]
---

<header 
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/80 backdrop-blur-md border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
    <!-- Mobile: centered logo + hamburger right | Desktop: logo left + nav right -->
    <div class="flex items-center justify-center lg:justify-start h-16 md:h-20">
      
      <!-- Logo - Centered on mobile, left on desktop -->
      <a href="/" class="flex items-center gap-2 md:gap-3 group">
        <img 
          src="/logolamercedpro.svg" 
          alt="U.E.P. Colegio La Merced" 
          class="w-10 h-10 md:w-12 md:h-12 object-contain"
        />
        <span class="hidden lg:block font-sans text-lg md:text-xl lg:text-2xl font-semibold tracking-wide text-gray-900">
          LA MERCED
        </span>
      </a>

      <!-- Desktop Navigation - Right side -->
      <nav class="hidden lg:flex items-center gap-1 ml-auto">
        {navLinksDesktop.map((link, index) => (
          <a 
            href={link.href}
            class:list={[
              "nav-link px-4 py-2 text-sm font-sans font-medium rounded-lg transition-all duration-200",
              link.highlight 
                ? "bg-accent-red text-white hover:bg-red-700 shadow-sm" 
                : "text-gray-600 hover:text-accent-red hover:bg-gray-50"
            ]}
            style={`--delay: ${index * 50}ms`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button - Right side -->
      <button 
        class="lg:hidden absolute right-4 p-2 text-gray-700 hover:text-accent-red transition-colors"
        aria-label="Abrir menú"
        id="mobile-menu-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" x2="21" y1="6" y2="6"/>
          <line x1="3" x2="21" y1="12" y2="12"/>
          <line x1="3" x2="21" y1="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Panel - White with Backdrop -->
<div 
  id="mobile-menu" 
  class="lg:hidden hidden fixed inset-0 z-50"
>
  <!-- Backdrop semitransparente -->
  <div id="mobile-backdrop" class="absolute inset-0 bg-white/95 backdrop-blur-lg opacity-0"></div>
  
  <!-- Contenido -->
  <div class="relative z-10 h-full">
    <!-- Close Button - Unicode X, Simple and Clean -->
    <button 
      id="close-menu-btn"
      class="fixed top-4 right-4 z-50 w-12 h-12 flex items-center justify-center bg-white rounded-full shadow-lg text-2xl text-gray-700 hover:bg-gray-100 hover:scale-110 transition-all duration-200 opacity-0"
      aria-label="Cerrar menú"
    >
      ✕
    </button>

    <!-- Menu Content - Slide from right -->
    <div id="menu-panel" class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-white shadow-2xl transform translate-x-full">
      <div class="px-5 pt-20 pb-8">
        <nav class="flex flex-col space-y-3">
          {navLinksMobile.map((link, index) => (
            <a 
              href={link.href}
              class:list={[
                "mobile-link block py-4 px-5 rounded-2xl text-base font-sans font-semibold text-center transition-all duration-300 transform shadow-md",
                "bg-accent-red text-white hover:bg-red-700 hover:shadow-xl hover:scale-[1.02]"
              ]}
              style={`--index: ${index}; --delay: ${index * 80}ms`}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* ========== DESKTOP NAV ========== */

  /* Staggered fade-in for desktop links */
  .nav-link {
    opacity: 0;
    transform: translateY(-10px);
    animation: navFadeIn 0.4s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes navFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ========== MOBILE MENU ========== */

  /* Staggered animation for mobile links - all red */
  .mobile-link {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu-open .mobile-link {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ========== MOBILE MENU ANIMATIONS ========== */

  /* Backdrop enter */
  @keyframes backdropIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Backdrop leave */
  @keyframes backdropOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  /* Panel slide in from right */
  @keyframes panelSlideIn {
    from {
      transform: translateX(100%);
    }
    to {
      transform: translateX(0);
    }
  }

  /* Panel slide out to right */
  @keyframes panelSlideOut {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(100%);
    }
  }

  /* Close button rotation */
  @keyframes closeBtnIn {
    from {
      opacity: 0;
      transform: rotate(-90deg) scale(0.8);
    }
    to {
      opacity: 1;
      transform: rotate(0deg) scale(1);
    }
  }

  /* Close button rotation out */
  @keyframes closeBtnOut {
    from {
      opacity: 1;
      transform: rotate(0deg) scale(1);
    }
    to {
      opacity: 0;
      transform: rotate(90deg) scale(0.8);
    }
  }

  /* Animation classes - Opening */
  body.mobile-menu-opening #mobile-backdrop {
    animation: backdropIn 0.3s ease-out forwards;
  }

  body.mobile-menu-opening #close-menu-btn {
    animation: closeBtnIn 0.25s ease-out 0.15s forwards;
  }

  body.mobile-menu-opening #menu-panel {
    animation: panelSlideIn 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  /* Animation classes - Closing */
  body.mobile-menu-closing #mobile-backdrop {
    animation: backdropOut 0.25s ease-in forwards;
  }

  body.mobile-menu-closing #close-menu-btn {
    animation: closeBtnOut 0.2s ease-in forwards;
  }

  body.mobile-menu-closing #menu-panel {
    animation: panelSlideOut 0.35s cubic-bezier(0.6, 0, 0.8, 1) forwards;
  }

  /* ========== MOBILE MENU OPEN STATE (Maintains visibility) ========== */
  body.mobile-menu-open #mobile-backdrop {
    opacity: 1;
  }

  body.mobile-menu-open #close-menu-btn {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  body.mobile-menu-open #menu-panel {
    transform: translateX(0);
  }

  body.mobile-menu-open #menu-panel .mobile-link {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ========== HEADER SCROLL EFFECTS ========== */

  /* Header scrolled state */
  .header-scrolled {
    background: rgba(255, 255, 255, 0.92) !important;
    backdrop-filter: blur(16px) !important;
    box-shadow: 0 2px 8px rgba(212, 175, 55, 0.15), 0 1px 3px rgba(212, 175, 55, 0.1) !important;
  }

  /* Header hidden (YouTube-style) */
  .header-hidden {
    transform: translateY(-100%);
  }

  /* ========== LOGO PULSE ========== */

  @keyframes logoPulse {
    0%, 100% {
      transform: scale(1);
      box-shadow: 0 4px 6px -1px rgba(206, 32, 41, 0.25);
    }
    50% {
      transform: scale(1.04);
      box-shadow: 0 6px 12px -2px rgba(206, 32, 41, 0.35);
    }
  }

  .logo-pulse {
    animation: logoPulse 3.5s ease-in-out infinite;
    animation-delay: 3s;
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('main-header')
    const menuBtn = document.getElementById('mobile-menu-btn')
    const closeBtn = document.getElementById('close-menu-btn')
    const mobileMenu = document.getElementById('mobile-menu')
    const menuLinks = mobileMenu?.querySelectorAll('.mobile-link')
    const body = document.body

    let lastScrollY = 0
    let ticking = false

    // ========== SMART NAVBAR (YouTube-style) ==========
    function updateHeader() {
      const currentScrollY = window.scrollY
      
      // Scrolled state
      if (currentScrollY > 50) {
        header?.classList.add('header-scrolled')
      } else {
        header?.classList.remove('header-scrolled')
      }

      // Hide/show on scroll direction (YouTube-style)
      if (currentScrollY > lastScrollY && currentScrollY > 150) {
        header?.classList.add('header-hidden')
      } else {
        header?.classList.remove('header-hidden')
      }

      lastScrollY = currentScrollY
      ticking = false
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updateHeader)
        ticking = true
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true })

    // ========== MOBILE MENU ==========
    
    function openMenu() {
      if (!mobileMenu) return
      
      mobileMenu.classList.remove('hidden')
      body.classList.add('mobile-menu-opening', 'mobile-menu-open')
      body.style.overflow = 'hidden'
      
      // Trigger staggered animations after panel appears
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          menuLinks?.forEach((link, index) => {
            const el = link as HTMLElement
            el.style.transitionDelay = `${200 + index * 60}ms`
          })
        })
      })
      
      // After animation completes, switch to static open state
      setTimeout(() => {
        body.classList.remove('mobile-menu-opening')
      }, 450)
    }

    function closeMenu() {
      if (!mobileMenu) return
      
      // Remove open state and add closing animation
      body.classList.remove('mobile-menu-open')
      body.classList.add('mobile-menu-closing')
      document.body.style.overflow = ''
      
      // Reset link delays for next open
      menuLinks?.forEach((link) => {
        const el = link as HTMLElement
        el.style.transitionDelay = ''
      })
      
      // Hide after animation completes
      setTimeout(() => {
        mobileMenu?.classList.add('hidden')
        body.classList.remove('mobile-menu-closing')
      }, 400)
    }

    // Event listeners
    menuBtn?.addEventListener('click', openMenu)
    closeBtn?.addEventListener('click', closeMenu)

    // Close on link click
    menuLinks?.forEach(link => {
      link.addEventListener('click', closeMenu)
    })

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu()
    })

    // Close on backdrop click
    const backdrop = document.getElementById('mobile-backdrop')
    backdrop?.addEventListener('click', closeMenu)

    // Initial state
    updateHeader()
  }

  // Initialize on page load
  initHeader()

  // Re-initialize after View Transitions
  document.addEventListener('astro:after-swap', initHeader)
</script>