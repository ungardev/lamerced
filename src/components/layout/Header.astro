---
interface Props {
  variant?: 'transparent' | 'solid'
}

const { variant = 'transparent' } = Astro.props

const navLinksDesktop = [
  { label: 'Nosotros', href: '/#nosotros' },
  { label: 'Valores', href: '/#valores' },
  { label: 'Galería', href: '/#galeria' },
  { label: 'Testimonios', href: '/#testimonios' },
  { label: 'Blog', href: '/blog' },
  { label: 'Admisiones', href: '/#admisiones', highlight: true },
]

const navLinksMobile = [
  { label: 'Home', href: '/' },
  { label: 'Nosotros', href: '/#nosotros' },
  { label: 'Valores', href: '/#valores' },
  { label: 'Galería', href: '/#galeria' },
  { label: 'Testimonios', href: '/#testimonios' },
  { label: 'Blog', href: '/blog' },
  { label: 'Admisiones', href: '/#admisiones', highlight: true },
  { label: 'Contacto', href: '/#footer' },
]
---

<header 
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/80 backdrop-blur-md border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
    <!-- Mobile: centered logo + hamburger right | Desktop: logo left + nav right -->
    <div class="flex items-center justify-center lg:justify-start h-16 md:h-20">
      
      <!-- Logo - Centered on mobile, left on desktop -->
      <a href="/" class="flex items-center gap-2 md:gap-3 group">
        <img 
          src="/logolamercedpro.svg" 
          alt="U.E.P. Colegio La Merced" 
          class="w-10 h-10 md:w-12 md:h-12 object-contain"
        />
        <span class="hidden lg:block font-montserrat text-lg md:text-xl lg:text-2xl font-extrabold uppercase tracking-tight text-accent-red" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.15);">
          LA MERCED
        </span>
      </a>

      <!-- Desktop Navigation - Right side -->
      <nav class="hidden lg:flex items-center gap-1 ml-auto">
        {navLinksDesktop.map((link, index) => (
          <a 
            href={link.href}
            class:list={[
              "nav-link px-4 py-2 text-sm font-sans font-medium rounded-lg transition-all duration-200",
              link.highlight 
                ? "bg-accent-red text-white hover:bg-red-700 shadow-sm" 
                : "text-gray-600 hover:text-accent-red hover:bg-gray-50"
            ]}
            style={`--delay: ${index * 50}ms`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button - Right side -->
      <button 
        class="lg:hidden absolute right-4 p-2 text-gray-700 hover:text-accent-red transition-colors"
        aria-label="Abrir menú"
        id="mobile-menu-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" x2="21" y1="6" y2="6"/>
          <line x1="3" x2="21" y1="12" y2="12"/>
          <line x1="3" x2="21" y1="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Panel - Glassmorphism with Backdrop -->
<div 
  id="mobile-menu" 
  class="lg:hidden hidden fixed inset-0 z-50"
>
  <!-- Backdrop - Glassmorphism blur -->
  <div id="mobile-backdrop" class="absolute inset-0 bg-black/30 backdrop-blur-xl opacity-0"></div>
  
  <!-- Menu Content - Slide from right -->
  <div id="menu-panel" class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-white/95 backdrop-blur-xl shadow-2xl transform translate-x-full flex flex-col">
    
    <!-- Header with Logo and Close Button -->
    <div class="relative pt-4 pb-3 px-4 border-b border-gray-100">
      <!-- Logo + Title - Perfectly Centered -->
      <div class="absolute left-1/2 -translate-x-1/2 flex flex-row items-center gap-2">
        <img 
          src="/logolamercedpro.svg" 
          alt="U.E.P. Colegio La Merced" 
          style="height: 2rem; width: auto; object-fit: contain; flex-shrink: 0;"
        />
        <span class="font-montserrat text-sm font-extrabold uppercase tracking-tight text-accent-red">
          LA MERCED
        </span>
      </div>
      
      <!-- Close Button - Positioned absolutely to the right -->
      <button 
        id="close-menu-btn"
        class="absolute right-4 top-4 w-10 h-10 rounded-full bg-white shadow-lg ring-2 ring-accent-red/20 hover:ring-accent-red/50 transition-all duration-200 flex items-center justify-center opacity-0"
        aria-label="Cerrar menú"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent-red">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>

    <!-- Navigation Links - Clean Link Style -->
    <nav class="flex-1 overflow-y-auto py-4 px-5">
      <div class="space-y-1">
        {navLinksMobile.slice(0, 6).map((link, index) => (
          <a 
            href={link.href}
            class:list={[
              "mobile-link flex items-center justify-between py-3 px-4 rounded-xl text-sm font-medium transition-all duration-200",
              "text-gray-700 hover:bg-gray-50 hover:text-accent-red"
            ]}
            style={`--index: ${index}; --delay: ${index * 40}ms`}
          >
            <span>{link.label}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 -translate-x-2 transition-all duration-200">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- CTA Section -->
      <div class="mt-6 pt-4 border-t border-gray-100">
        <a 
          href="/#admisiones"
          class:list={[
            "mobile-link block py-3.5 px-4 rounded-xl text-sm font-bold text-center transition-all duration-200",
            "bg-accent-red text-white hover:bg-red-700 shadow-lg shadow-red-200"
          ]}
          style="--delay: 240ms"
        >
          Admisiones 2025-2026
        </a>
      </div>

      <!-- Contact Info -->
      <div class="mt-6 pt-4 border-t border-gray-100 space-y-2">
        <a href="tel:+582123558070" class="flex items-center gap-3 py-2 px-4 text-xs text-gray-500 hover:text-accent-red transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span>0212-355-80-70</span>
        </a>
        <a href="mailto:colegiolamerced@gmail.com" class="flex items-center gap-3 py-2 px-4 text-xs text-gray-500 hover:text-accent-red transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          <span>colegiolamerced@gmail.com</span>
        </a>
      </div>
    </nav>
  </div>
</div>

<style is:global>
  /* ========== MONTSERRAT FONT FOR HEADER LOGO ========== */
  .font-montserrat {
    font-family: 'Montserrat', sans-serif;
  }

  /* ========== DESKTOP NAV ========== */

  /* Staggered fade-in for desktop links */
  .nav-link {
    opacity: 0;
    transform: translateY(-10px);
    animation: navFadeIn 0.4s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes navFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ========== MOBILE MENU ========== */

  /* Simplified mobile link animations */
  .mobile-link {
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.2s ease;
    will-change: transform, opacity;
  }

  .mobile-link svg {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .mobile-link:hover svg {
    opacity: 1 !important;
    transform: translateX(0) !important;
  }

  .mobile-menu-open .mobile-link {
    opacity: 1;
    transform: translateX(0);
  }

  /* ========== MOBILE MENU ANIMATIONS (Simplified) ========== */

  /* Backdrop */
  @keyframes backdropIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes backdropOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  /* Panel slide */
  @keyframes panelSlideIn {
    from { transform: translateX(100%); }
    to { transform: translateX(0); }
  }

  @keyframes panelSlideOut {
    from { transform: translateX(0); }
    to { transform: translateX(100%); }
  }

  /* Close button */
  @keyframes closeBtnIn {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes closeBtnOut {
    from { opacity: 1; transform: scale(1); }
    to { opacity: 0; transform: scale(0.8); }
  }

  /* Opening */
  body.mobile-menu-opening #mobile-backdrop {
    animation: backdropIn 0.25s ease-out forwards;
  }

  body.mobile-menu-opening #close-menu-btn {
    animation: closeBtnIn 0.2s ease-out 0.15s forwards;
  }

  body.mobile-menu-opening #menu-panel {
    animation: panelSlideIn 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  /* Closing */
  body.mobile-menu-closing #mobile-backdrop {
    animation: backdropOut 0.2s ease-in forwards;
  }

  body.mobile-menu-closing #close-menu-btn {
    animation: closeBtnOut 0.15s ease-in forwards;
  }

  body.mobile-menu-closing #menu-panel {
    animation: panelSlideOut 0.3s cubic-bezier(0.6, 0, 0.8, 1) forwards;
  }

  /* Open state */
  body.mobile-menu-open #mobile-backdrop {
    opacity: 1;
  }

  body.mobile-menu-open #close-menu-btn {
    opacity: 1;
    transform: scale(1);
  }

  body.mobile-menu-open #menu-panel {
    transform: translateX(0);
  }

  body.mobile-menu-open .mobile-link {
    opacity: 1;
    transform: translateX(0);
  }

  /* ========== HEADER SCROLL EFFECTS ========== */

  .header-scrolled {
    background: rgba(255, 255, 255, 0.92) !important;
    backdrop-filter: blur(16px) !important;
    box-shadow: 0 2px 8px rgba(212, 175, 55, 0.15), 0 1px 3px rgba(212, 175, 55, 0.1) !important;
  }

  .header-hidden {
    transform: translateY(-100%);
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('main-header')
    const menuBtn = document.getElementById('mobile-menu-btn')
    const closeBtn = document.getElementById('close-menu-btn')
    const mobileMenu = document.getElementById('mobile-menu')
    const menuLinks = mobileMenu?.querySelectorAll('.mobile-link')
    const body = document.body

    let lastScrollY = 0
    let ticking = false

    // ========== SMART NAVBAR (YouTube-style) ==========
    function updateHeader() {
      const currentScrollY = window.scrollY
      
      if (currentScrollY > 50) {
        header?.classList.add('header-scrolled')
      } else {
        header?.classList.remove('header-scrolled')
      }

      if (currentScrollY > lastScrollY && currentScrollY > 150) {
        header?.classList.add('header-hidden')
      } else {
        header?.classList.remove('header-hidden')
      }

      lastScrollY = currentScrollY
      ticking = false
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updateHeader)
        ticking = true
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true })

    // ========== MOBILE MENU ==========
    
    function openMenu() {
      if (!mobileMenu) return
      
      mobileMenu.classList.remove('hidden')
      body.classList.add('mobile-menu-opening', 'mobile-menu-open')
      body.style.overflow = 'hidden'
      
      // Staggered link animations
      requestAnimationFrame(() => {
        menuLinks?.forEach((link, index) => {
          const el = link as HTMLElement
          el.style.transitionDelay = `${150 + index * 50}ms`
        })
      })
      
      setTimeout(() => {
        body.classList.remove('mobile-menu-opening')
      }, 400)
    }

    function closeMenu() {
      if (!mobileMenu) return
      
      body.classList.remove('mobile-menu-open')
      body.classList.add('mobile-menu-closing')
      document.body.style.overflow = ''
      
      menuLinks?.forEach((link) => {
        const el = link as HTMLElement
        el.style.transitionDelay = ''
      })
      
      setTimeout(() => {
        mobileMenu?.classList.add('hidden')
        body.classList.remove('mobile-menu-closing')
      }, 350)
    }

    // Event listeners
    menuBtn?.addEventListener('click', openMenu)
    closeBtn?.addEventListener('click', closeMenu)

    // Close on link click
    menuLinks?.forEach(link => {
      link.addEventListener('click', closeMenu)
    })

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu()
    })

    // Close on backdrop click
    const backdrop = document.getElementById('mobile-backdrop')
    backdrop?.addEventListener('click', closeMenu)

    // Swipe to dismiss (touch gesture)
    let touchStartX = 0
    let touchEndX = 0
    
    const menuPanel = document.getElementById('menu-panel')
    menuPanel?.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX
    }, { passive: true })
    
    menuPanel?.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX
      // If swiped left more than 100px, close menu
      if (touchStartX - touchEndX > 100 && touchEndX < 50) {
        closeMenu()
      }
    }, { passive: true })

    updateHeader()
  }

  initHeader()
  document.addEventListener('astro:after-swap', initHeader)
</script>