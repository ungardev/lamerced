---
const currentYear = new Date().getFullYear()

const footerLinks = {
  institucional: [
    { label: 'Historia', href: '#nosotros' },
    { label: 'Misión y Visión', href: '#nosotros' },
    { label: 'Valores', href: '#valores' },
    { label: 'Equipo Directivo', href: '#nosotros' },
  ],
  academics: [
    { label: 'Nivel Inicial', href: '/' },
    { label: 'Primaria', href: '/' },
    { label: 'Media General', href: '/' },
    { label: 'Calendario Académico', href: '/' },
  ],
  contact: [
    { label: 'Admisiones', href: '#admisiones' },
    { label: 'Contactar', href: '#contacto' },
    { label: 'Preguntas Frecuentes', href: '/' },
  ],
}
---

<footer id="footer" class="bg-white border-t border-gray-100 w-full max-w-full overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 w-full max-w-full">
      <!-- Brand -->
      <div class="lg:col-span-1 sm:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4">
          <div class="w-11 h-11 rounded-full bg-accent-red flex items-center justify-center shadow-md">
            <span class="text-white font-serif text-xl font-medium">M</span>
          </div>
          <div>
            <span class="font-serif text-lg font-medium text-gray-900 block leading-tight">Colegio</span>
            <span class="font-serif text-sm text-accent-red block leading-tight">La Merced</span>
          </div>
        </a>
        <p class="text-sm text-gray-500 mb-4 leading-relaxed">
          Más de 69 años formando líderes con valores mercedarios: solidaridad, respeto, justicia y servicio.
        </p>
        <div class="flex gap-3">
          <a href="https://www.instagram.com/uepcolegiolamerced/" target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-gray-50 flex items-center justify-center shadow-sm hover:bg-accent-red hover:text-white transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
          </a>
          <a href="https://facebook.com/uepcolegiolamerced" target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-gray-50 flex items-center justify-center shadow-sm hover:bg-accent-red hover:text-white transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Institucional -->
      <div>
        <h4 class="font-serif text-base font-medium mb-4 text-gray-900">Institucional</h4>
        <ul class="space-y-2.5">
          {footerLinks.institucional.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-accent-red transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Académico -->
      <div>
        <h4 class="font-serif text-base font-medium mb-4 text-gray-900">Académico</h4>
        <ul class="space-y-2.5">
          {footerLinks.academics.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-accent-red transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="font-serif text-base font-medium mb-4 text-gray-900">Contacto</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 text-accent-red shrink-0">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-sm text-gray-500">Caraballeda, Edo. La Guaira<br/>Venezuela</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-red shrink-0">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span class="text-sm text-gray-500">0212-355-80-70</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-red shrink-0">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <span class="text-sm text-gray-500">colegiolamerced@gmail.com</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-6 border-t border-gray-100">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-gray-400 text-center md:text-left">
          © {currentYear} U.E.P. Colegio La Merced. Todos los derechos reservados.
        </p>
        <div class="flex items-center gap-6">
          <a href="#" class="text-sm text-gray-400 hover:text-accent-red transition-colors duration-200">Política de Privacidad</a>
          <a href="#" class="text-sm text-gray-400 hover:text-accent-red transition-colors duration-200">Términos</a>
        </div>
      </div>
    </div>
  </div>
</footer>