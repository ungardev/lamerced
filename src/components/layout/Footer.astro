---
const currentYear = new Date().getFullYear()

const footerLinks = {
  institucional: [
    { label: 'Historia', href: '#nosotros' },
    { label: 'Misión y Visión', href: '#nosotros' },
    { label: 'Valores', href: '#valores' },
    { label: 'Equipo Directivo', href: '#nosotros' },
  ],
  academics: [
    { label: 'Nivel Inicial', href: '/' },
    { label: 'Primaria', href: '/' },
    { label: 'Media General', href: '/' },
    { label: 'Calendario Académico', href: '/' },
  ],
  contact: [
    { label: 'Admisiones', href: '#admisiones' },
    { label: 'Contactar', href: '#contacto' },
    { label: 'Preguntas Frecuentes', href: '/' },
  ],
}
---

<footer class="bg-secondary border-t w-full max-w-full overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-12 w-full max-w-full">
      <!-- Brand -->
      <div class="lg:col-span-1 sm:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 rounded-full bg-accent-red flex items-center justify-center shadow-lg">
            <span class="text-white font-serif text-xl font-bold">M</span>
          </div>
          <div>
            <span class="font-serif text-lg font-bold text-foreground block leading-tight">Colegio</span>
            <span class="font-serif text-sm text-accent-red block leading-tight">La Merced</span>
          </div>
        </a>
        <p class="text-sm text-muted-foreground mb-4">
          Educación de excelencia con más de 50 años de tradición mercedaria, formando líderes del futuro con innovación tecnológica.
        </p>
        <div class="flex gap-4">
          <a href="https://www.instagram.com/uepcolegiolamerced/" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm hover:bg-accent-red hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm hover:bg-accent-red hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a5 5 0 0 1 5-5z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Institucional -->
      <div>
        <h4 class="font-serif text-lg font-semibold mb-4 text-foreground">Institucional</h4>
        <ul class="space-y-3">
          {footerLinks.institucional.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-accent-red transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Académico -->
      <div>
        <h4 class="font-serif text-lg font-semibold mb-4 text-foreground">Académico</h4>
        <ul class="space-y-3">
          {footerLinks.academics.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-accent-red transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="font-serif text-lg font-semibold mb-4 text-foreground">Contacto</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 text-accent-red shrink-0">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-sm text-muted-foreground">Caraballeda, Edo. La Guaira<br/>Venezuela</span>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-red shrink-0">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span class="text-sm text-muted-foreground">0212-355-80-70</span>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-red shrink-0">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <span class="text-sm text-muted-foreground">colegiolamerced@gmail.com</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-border">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-muted-foreground text-center md:text-left">
          © {currentYear} U.E.P. Colegio La Merced. Todos los derechos reservados.
        </p>
        <div class="flex items-center gap-6">
          <a href="#" class="text-sm text-muted-foreground hover:text-accent-red transition-colors duration-200">Política de Privacidad</a>
          <a href="#" class="text-sm text-muted-foreground hover:text-accent-red transition-colors duration-200">Términos y Condiciones</a>
        </div>
      </div>
    </div>
  </div>
</footer>